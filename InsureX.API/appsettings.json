
   {
     "Logging": {
       "LogLevel": {
         "Default": "Information",
         "Microsoft.AspNetCore": "Warning"
       }
     },
     "AllowedHosts": "*",
     "ConnectionStrings": {
       "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=InsurexDb;Trusted_Connection=True;TrustServerCertificate=True;"
     },
     "Jwt": {
    "Secret": "your-super-secret-key-with-at-least-32-characters-here",
    "Issuer": "InsureX",
    "Audience": "InsureX Clients",
    "ExpirationMinutes": 60
  },
     "FileStorage": {
       "Path": "uploads",
       "MaxFileSize": 10485760,
       "AllowedExtensions": [".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx"]
     },
     "Email": {
       "SmtpServer": "smtp.gmail.com",
       "SmtpPort": 587,
       "SmtpUsername": "your-email@gmail.com",
       "SmtpPassword": "your-app-password",
       "FromEmail": "noreply@insurex.com",
       "FromName": "Insurex Platform"
     }
   }